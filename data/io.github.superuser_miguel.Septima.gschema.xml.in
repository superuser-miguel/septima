<?xml version="1.0" encoding="UTF-8"?>
<schemalist>
  <schema id="@app-id@" path="@gschema-path@">
    <key name="compression-presets" type="as">
      <default>[]</default>
      <summary>Saved compression presets</summary>
      <description>
        Each entry is one preset, its fields joined by the unit-separator
        character (U+001F): name, format, codec, level, threads, dictionary,
        solid, volume, bcj, encrypt-headers, extra-params. Passwords are never
        stored.
      </description>
    </key>
  </schema>
</schemalist>
