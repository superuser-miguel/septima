<component type="desktop-application">
  <id>@app-id@</id>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>GPL-3.0-or-later</project_license>
  <name>Septima</name>
  <summary>Browse and create modern-codec 7-Zip archives</summary>
  <description>
    <p>
      Septima is a GTK frontend for 7-Zip ZS (7zz) that speaks modern
      compression codecs — Zstandard, Brotli and Fast-LZMA2 — with a real
      compression-tuning interface. It is an archive tool, not a file manager.
    </p>
  </description>
  <launchable type="desktop-id">@app-id@.desktop</launchable>
  <screenshots>
    <screenshot type="default">
      <caption>Choosing a modern codec in the Add-to-Archive dialog</caption>
      <image>https://raw.githubusercontent.com/superuser-miguel/septima/main/docs/screenshots/codec-menu.png</image>
    </screenshot>
    <screenshot>
      <caption>Reactive tuning with a live memory estimate</caption>
      <image>https://raw.githubusercontent.com/superuser-miguel/septima/main/docs/screenshots/create-dialog.png</image>
    </screenshot>
    <screenshot>
      <caption>Executable optimization, split volumes and encryption</caption>
      <image>https://raw.githubusercontent.com/superuser-miguel/septima/main/docs/screenshots/create-options.png</image>
    </screenshot>
    <screenshot>
      <caption>Opening an archive</caption>
      <image>https://raw.githubusercontent.com/superuser-miguel/septima/main/docs/screenshots/welcome.png</image>
    </screenshot>
  </screenshots>
  <url type="homepage">https://github.com/superuser-miguel/septima</url>
  <url type="bugtracker">https://github.com/superuser-miguel/septima/issues</url>
  <developer id="io.github.superuser_miguel">
    <name>Miguel Almanzar</name>
  </developer>
  <content_rating type="oars-1.1"/>
  <releases>
    <release version="0.1.0" date="2026-07-11">
      <description>
        <p>First release.</p>
        <ul>
          <li>Browse, extract (with progress, cancel and password support), and create archives.</li>
          <li>Modern codecs — Zstandard, Brotli, Fast-LZMA2, LZ4/LZ5 and Lizard, alongside LZMA2, PPMd and BZip2.</li>
          <li>A compression-tuning dialog with reactive level ranges, a live memory estimate, split volumes and named presets.</li>
          <li>Transparent modern tarballs — create, browse and extract .tar.zst / .tar.xz in one gesture.</li>
          <li>A checksum calculator (CRC, SHA-256/512, SHA3, BLAKE3, xxHash) with verify-against-a-checksum-file.</li>
        </ul>
      </description>
    </release>
  </releases>
</component>
